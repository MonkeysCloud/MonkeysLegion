{
  "name": "monkeyscloud/monkeyslegion",
  "description": "Meta-package for the full MonkeysLegion stack",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "monkeyscloud/monkeyslegion-session": "^1.0",
    "monkeyscloud/monkeyslegion-mlc": "^3.1",
    "monkeyscloud/monkeyslegion-template": "^1.0",
    "monkeyscloud/monkeyslegion-router": "^2.1",
    "monkeyscloud/monkeyslegion-migration": "^1.0",
    "monkeyscloud/monkeyslegion-http": "^2.1",
    "monkeyscloud/monkeyslegion-entity": "^1.0",
    "monkeyscloud/monkeyslegion-di": "^1.0",
    "monkeyscloud/monkeyslegion-dev-server": "^1.0",
    "monkeyscloud/monkeyslegion-database": "^1.0",
    "monkeyscloud/monkeyslegion-core": "^1.1",
    "monkeyscloud/monkeyslegion-cli": "2.x-dev as 1.0.0",
    "monkeyscloud/monkeyslegion-telemetry": "^2.0",
    "monkeyscloud/monkeyslegion-events": "^1.0",
    "monkeyscloud/monkeyslegion-validation": "^1.0",
    "monkeyscloud/monkeyslegion-query": "^1.0",
    "monkeyscloud/monkeyslegion-i18n": "^2.0",
    "monkeyscloud/monkeyslegion-auth": "^2.0",
    "monkeyscloud/monkeyslegion-mail": "^2.0",
    "monkeyscloud/monkeyslegion-logger": "^1.0",
    "monolog/monolog": "^3.9",
    "vlucas/phpdotenv": "^5.6",
    "monkeyscloud/monkeyslegion-files": "^2.0",
    "monkeyscloud/monkeyslegion-cache": "^1.0",
    "monkeyscloud/monkeyslegion-queue": "dev-main as 1.1.0",
    "monkeyscloud/monkeyslegion-schedule": "^1.0",
    "monkeyscloud/monkeyslegion-env": "^1.0",
    "monkeyscloud/monkeyslegion-openapi": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\": "src/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.0.x-dev"
    },
    "monkeyslegion": {
      "providers": [
        "MonkeysLegion\\Config\\AppConfig"
      ]
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../MonkeysLegion-Files",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../MonkeysLegion-Queue",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "path",
      "url": "../MonkeysLegion-Cli",
      "options": {
        "symlink": true
      }
    }
  ]
}
