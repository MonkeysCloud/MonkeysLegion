{
    "name": "monkeyscloud/monkeyslegion",
    "description": "High-performance PHP 8.4 framework — attribute-first architecture, property hooks, compiled DI, MLC configuration.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "monkeyscloud/monkeyslegion-contracts": "^2.0",
        "monkeyscloud/monkeyslegion-core": "^2.0",
        "monkeyscloud/monkeyslegion-di": "^2.0",
        "monkeyscloud/monkeyslegion-http": "^2.0",
        "monkeyscloud/monkeyslegion-router": "^2.1",
        "monkeyscloud/monkeyslegion-entity": "^2.0",
        "monkeyscloud/monkeyslegion-database": "^2.0",
        "monkeyscloud/monkeyslegion-query": "^2.0",
        "monkeyscloud/monkeyslegion-migration": "^2.0",
        "monkeyscloud/monkeyslegion-auth": "^2.1",
        "monkeyscloud/monkeyslegion-validation": "^2.0",
        "monkeyscloud/monkeyslegion-cache": "^2.0",
        "monkeyscloud/monkeyslegion-session": "^2.0",
        "monkeyscloud/monkeyslegion-template": "^2.0",
        "monkeyscloud/monkeyslegion-events": "^2.0",
        "monkeyscloud/monkeyslegion-queue": "^1.2",
        "monkeyscloud/monkeyslegion-schedule": "^1.1",
        "monkeyscloud/monkeyslegion-mail": "^1.1",
        "monkeyscloud/monkeyslegion-i18n": "^2.1",
        "monkeyscloud/monkeyslegion-telemetry": "^2.0",
        "monkeyscloud/monkeyslegion-logger": "^2.0",
        "monkeyscloud/monkeyslegion-files": "^2.0",
        "monkeyscloud/monkeyslegion-mlc": "^3.2",
        "monkeyscloud/monkeyslegion-cli": "^2.0",
        "monkeyscloud/monkeyslegion-dev-server": "^1.0",
        "monkeyscloud/monkeyslegion-apex": "^1.0",
        "monkeyscloud/monkeyslegion-openapi": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "MonkeysLegion\\": "src/"
        },
        "files": [
            "bootstrap/env.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MonkeysLegion\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0.x-dev"
        },
        "monkeyslegion": {
            "providers": [
                "MonkeysLegion\\Config\\AppConfig"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=9 src/",
        "lint": "find src/ -name '*.php' -exec php -l {} \\;"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}