# MonkeysLegion v2 — Application Configuration
# Environment variables are referenced with env("VAR_NAME", "default")

app {
    name     = env("APP_NAME", "MonkeysLegion")
    env      = env("APP_ENV", "production")
    debug    = env("APP_DEBUG", false)
    url      = env("APP_URL", "http://localhost:8080")
    timezone = env("APP_TIMEZONE", "UTC")
    version  = "2.0.0"
    key      = env("APP_KEY", "")
    locale   = "en"
}
