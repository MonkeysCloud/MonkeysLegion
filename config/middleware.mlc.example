# MonkeysLegion v2 — Middleware Pipeline Configuration
# Order matters: middleware is executed top-to-bottom on request, bottom-to-top on response.
# All middleware classes below come from the framework packages.

middleware {
    global = [
        "MonkeysLegion\\Http\\Middleware\\RequestIdMiddleware",
        "MonkeysLegion\\Http\\Middleware\\SecurityHeadersMiddleware",
        "MonkeysLegion\\Framework\\Middleware\\MaintenanceModeMiddleware",
        "MonkeysLegion\\Http\\Middleware\\ErrorHandlerMiddleware",
        "MonkeysLegion\\Http\\Middleware\\LoggingMiddleware",
        "MonkeysLegion\\Http\\Middleware\\CorsMiddleware",
        "MonkeysLegion\\Http\\Middleware\\RateLimitMiddleware",
        "MonkeysLegion\\Session\\Middleware\\SessionMiddleware",
        "MonkeysLegion\\Session\\Middleware\\VerifyCsrfToken",
        "MonkeysLegion\\Auth\\Middleware\\AuthenticationMiddleware",
        "MonkeysLegion\\Telemetry\\Middleware\\RequestMetricsMiddleware",
    ]
}

# Rate limiting
rate_limit {
    max_requests   = 5000
    window_seconds = 60
}

# Maintenance mode bypass
maintenance {
    allowed_ips = []
    secret      = env("MAINTENANCE_SECRET", "")
}
