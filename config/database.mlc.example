# MonkeysLegion v2 — Database Configuration

database {
    default = env("DB_CONNECTION", "mysql")

    connections {
        mysql {
            driver   = "mysql"
            host     = env("DB_HOST", "127.0.0.1")
            port     = env("DB_PORT", 3306)
            database = env("DB_DATABASE", "monkeyslegion")
            username = env("DB_USERNAME", "root")
            password = env("DB_PASSWORD", "")
            charset  = "utf8mb4"
            collation = "utf8mb4_unicode_ci"
            prefix   = ""
            strict   = true
            pool {
                min = 2
                max = 10
            }
        }

        pgsql {
            driver   = "pgsql"
            host     = env("DB_HOST", "127.0.0.1")
            port     = env("DB_PORT", 5432)
            database = env("DB_DATABASE", "monkeyslegion")
            username = env("DB_USERNAME", "root")
            password = env("DB_PASSWORD", "")
            charset  = "utf8"
            schema   = "public"
        }

        sqlite {
            driver   = "sqlite"
            database = env("DB_DATABASE", "var/database.sqlite")
        }
    }

    migrations {
        table     = "migrations"
        directory = "database/migrations"
    }
}
