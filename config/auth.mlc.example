# MonkeysLegion v2 — Auth Configuration

auth {
    # JWT
    jwt_secret  = env("JWT_SECRET", "")
    access_ttl  = 1800     # 30 minutes
    refresh_ttl = 604800   # 7 days
    jwt_leeway  = 60
    issuer      = env("APP_URL", "http://localhost:8080")
    audience    = null

    # Password Hashing
    password {
        algorithm = "argon2id"  # bcrypt | argon2id | default
        cost      = 12
    }

    # Users
    users {
        table = "users"
        model = "App\\Entity\\User"
    }

    # Rate Limiting
    rate_limit {
        enabled        = true
        driver         = "cache"   # cache | redis | memory
        max_attempts   = 60
        lockout_seconds = 60
    }

    # Token Storage
    token_storage {
        driver = "memory"  # memory | redis
        prefix = "auth:"
    }

    # Public paths (no authentication required)
    public_paths = [
        "/",
        "/login",
        "/register",
        "/api/auth/login",
        "/api/auth/register",
        "/api/auth/refresh",
        "/health",
    ]

    # Two-Factor Authentication
    two_factor {
        issuer = env("APP_NAME", "MonkeysLegion")
    }
}

# OAuth2 Providers
oauth {
    google {
        enabled       = env("OAUTH_GOOGLE_ENABLED", false)
        client_id     = env("OAUTH_GOOGLE_CLIENT_ID", "")
        client_secret = env("OAUTH_GOOGLE_CLIENT_SECRET", "")
        redirect_uri  = "/oauth/google/callback"
    }

    github {
        enabled       = env("OAUTH_GITHUB_ENABLED", false)
        client_id     = env("OAUTH_GITHUB_CLIENT_ID", "")
        client_secret = env("OAUTH_GITHUB_CLIENT_SECRET", "")
        redirect_uri  = "/oauth/github/callback"
    }
}

# RBAC
rbac {
    roles = []
}
